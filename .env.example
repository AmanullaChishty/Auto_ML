AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=ap-south-1
S3_BUCKET=s3://your-bucket-name
MLFLOW_S3_BUCKET=s3://your-bucket-name/mlflow
# Choose only one warehouse source:
WAREHOUSE=redshift   # or snowflake
# Redshift
REDSHIFT_HOST=...
REDSHIFT_PORT=5439
REDSHIFT_DB=...
REDSHIFT_USER=...
REDSHIFT_PASSWORD=...
REDSHIFT_SCHEMA=public
REDSHIFT_SQL=SELECT * FROM your_schema.your_table;
# Snowflake
SNOWFLAKE_ACCOUNT=xy12345.ap-southeast-1
SNOWFLAKE_USER=...
SNOWFLAKE_PASSWORD=...
SNOWFLAKE_ROLE=...
SNOWFLAKE_WAREHOUSE=...
SNOWFLAKE_DATABASE=...
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_SQL=SELECT * FROM YOUR_DB.PUBLIC.YOUR_TABLE;
# LLM (OpenAI-compatible) — works with OpenAI or local vLLM/Ollama/LM Studio
LLM_API_BASE=https://api.openai.com/v1     
LLM_API_KEY=...                            
LLM_MODEL=gpt-4o-mini                      
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=3000
